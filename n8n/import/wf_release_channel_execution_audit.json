      "typeVersion": 4.2,
      "position": [
        -120,
        40
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json; return [{json:{status: body.status || 'ok', count: body.count || 0, items: (body.items || []).map(item => ({channel_name:item.channel_name, release_version:item.release_version, execution_mode:item.execution_mode, execution_status:item.execution_status, delivery_ref:item.delivery_ref || null, output_path:item.output_path || null}))}}];"
      },
      "id": "code-2",
      "name": "Normalize Response",
      "type": "n8n-nodes-base.code",
