      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -780,
        40
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{json:{tenant_id:'default', limit:20}}];"
      },
      "id": "code-1",
      "name": "Build Query",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -460,
        40
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={($env.SERVICE_BASE_URL || 'http://host.docker.internal:8000').replace(/\\/$/, '') + '/release/channel-executions?tenant_id=' + encodeURIComponent($json.tenant_id || 'default') + '&limit=' + encodeURIComponent(String($json.limit || 20))}",
        "options": {
          "timeout": 180000
        }
      },
      "id": "http-1",
      "name": "Backend Request",
