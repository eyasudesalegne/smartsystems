{
  "name": "wf_release_channel_execution_audit",
  "nodes": [
    {
      "parameters": {
        "content": "wf_release_channel_execution_audit reads /release/channel-executions so operators can audit dry-runs, prepared deliveries, blocked channels, and executed channel refs after a release staging run."
      },
      "id": "note-1",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -820,
        -140
      ]
    },
    {
      "parameters": {},
