{
  "name": "wf_rag_document_ingest_governed",
  "nodes": [
    {
      "parameters": {
        "content": "wf_rag_document_ingest_governed submits a governed document into /rag/documents/ingest so chunk and embedding-version tracking are captured in the control plane."
      },
      "id": "3d9a49e0-a388-425d-a228-d5fbd6289907",
      "name": "Overview",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -820,
        -140
      ]
    },
    {
      "parameters": {},
