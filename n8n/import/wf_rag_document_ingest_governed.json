      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -780,
        40
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{json:{tenant_id: $env.DEFAULT_TENANT_ID || 'default', actor_id: 'operator', source_ref: 'docs:sample', title: 'Governed sample document', body: 'This is a governed sample document for RAG ingestion.', mime_type: 'text/plain', metadata: {classification: 'internal', source_system: 'n8n'}}}];"
      },
      "id": "135f63ff-d3c9-4548-ad03-966f43b84263",
      "name": "Build Document Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -470,
        40
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.SERVICE_BASE_URL || 'http://host.docker.internal:8000').replace(/\\/$/, '') + '/rag/documents/ingest' }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "c05a7f38-00ba-4223-a941-255c293d9df9",
      "name": "Ingest Governed Document",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -110,
        40
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || $json; return [{json:{status: body.status || 'ok', document_id: body.document_id, source_ref: body.source_ref, chunks_created: body.chunks_created, vector_mode: body.vector_mode, embedding_model: body.embedding_model, raw: body}}];"
      },
