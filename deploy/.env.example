VSCODE_BRIDGE_MODE=workspace_bundle
VSCODE_BRIDGE_URL=http://localhost:8765
VSCODE_ACCESS_TOKEN=__REPLACE_ME__
AUTH_REQUIRED=false
JWT_SECRET=__REPLACE_ME__
JWT_ISSUER=hybrid-control-plane
JWT_EXPIRY_SECONDS=3600
AUTH_BOOTSTRAP_USERS_RAW=admin:admin,operator:operator,viewer:viewer,svc:service_account
SECRET_ENCRYPTION_KEY=
ENABLE_IDEMPOTENCY=true
LOG_JSON=true
CORRELATION_HEADER_NAME=x-correlation-id

QUEUE_BACKEND=db
REDIS_URL=redis://redis:6379/0
QUEUE_BACKEND_NAMESPACE=controlplane
WORKER_CONCURRENCY=4
QUEUE_MAX_CLAIM_BATCH=16
RETRY_BACKOFF_BASE_SECONDS=15
RETRY_BACKOFF_MAX_SECONDS=1800
RETRY_BACKOFF_JITTER_SECONDS=5
CONNECTOR_RATE_LIMIT_WINDOW_SECONDS=60
CONNECTOR_RATE_LIMIT_MAX_REQUESTS=30
CONNECTOR_CIRCUIT_BREAKER_THRESHOLD=5
CONNECTOR_CIRCUIT_BREAKER_RESET_SECONDS=300
CONNECTOR_TIMEOUT_CAP_SECONDS=90
WORKFLOW_EXECUTION_CAP_WINDOW_SECONDS=60
WORKFLOW_EXECUTION_CAP_MAX_REQUESTS=120

RELEASE_ARTIFACT_DIR=artifacts
RELEASE_CHANNEL_DEFAULT_TYPE=manual_inspection
RELEASE_CHANNEL_DEFAULT_DESTINATION=artifacts/release_channel_drops

LIFECYCLE_DEFAULT_RETAIN_DAYS=30
LIFECYCLE_CLEANUP_BATCH_SIZE=500
LIFECYCLE_ARCHIVE_DEAD_LETTERS=true

TENANT_DEFAULT_ID=default
STRICT_TENANT_ENFORCEMENT=false
TENANT_HEADER_NAME=x-tenant-id
TENANT_ALLOW_ADMIN_OVERRIDE=true
STRICT_TENANT_ROW_ISOLATION=false
TENANT_ROW_POLICY_DEFAULT_STRICT_MODE=inherit
TENANT_ROW_POLICY_DEFAULT_REQUIRE_TENANT_MATCH=true
RELEASE_CHANNEL_EXECUTION_DIR=artifacts/release_channel_executions
RELEASE_CHANNEL_EXECUTE_WEBHOOKS=false
