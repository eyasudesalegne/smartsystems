  "supported_operations": [
    {
      "operation_id": "list_courses",
      "method": "GET",
      "path": "/api/v1/courses",
      "description": "List courses from a Canvas LMS instance. Assumes Canvas means Canvas LMS."
    },
    {
      "operation_id": "get_course",
      "method": "GET",
      "path": "/api/v1/courses/__CANVAS_COURSE_ID__",
      "description": "Get one course."
    },
    {
      "operation_id": "list_modules",
      "method": "GET",
      "path": "/api/v1/courses/__CANVAS_COURSE_ID__/modules",
      "description": "List modules for a course."
    }
  ],
