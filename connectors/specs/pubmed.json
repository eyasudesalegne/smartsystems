      "operation_id": "search",
      "method": "GET",
      "path": "/entrez/eutils/esearch.fcgi?db=pubmed&retmode=json&term=__PUBMED_TERM__",
      "description": "Search PubMed and return PMIDs."
    },
    {
      "operation_id": "summary",
      "method": "GET",
      "path": "/entrez/eutils/esummary.fcgi?db=pubmed&retmode=json&id=__PUBMED_IDS__",
      "description": "Fetch PubMed summaries by PMID list."
    },
    {
      "operation_id": "fetch_abstracts",
      "method": "GET",
      "path": "/entrez/eutils/efetch.fcgi?db=pubmed&retmode=text&rettype=abstract&id=__PUBMED_IDS__",
      "description": "Fetch abstracts in text form."
    }
